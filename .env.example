# Just-recipe env vars for host runs. Loaded automatically by `just` via
# `set dotenv-load := true` in the justfile. `initial-setup` copies this to
# `.env` (gitignored).

# Selects which `application-<env>.conf` the server loads at boot.
APP_ENV=local

# Hostname for `just db-migrate`'s flyway JDBC URL.
MYSQL_HOST=localhost

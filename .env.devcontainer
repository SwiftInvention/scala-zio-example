# Devcontainer env vars. Read directly by `.devcontainer/compose-all.yml`'s
# agent service via `env_file: ../.env.devcontainer`, so these values populate
# the agent's process environment when the devcontainer starts.

# Disable Claude Code's non-essential outbound traffic (telemetry, etc.) —
# only the API calls the agent makes for its actual work reach the proxy.
CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Same `local` env as the host, with ${?VAR} overrides in application-local.conf
# pointing the app at the inline compose services instead of host localhost.
APP_ENV=local

# Override the local jdbc-url to reach the inline `mysql` compose service.
MYSQL_URL=jdbc:mysql://mysql:3306/localDatabase?useUnicode=true&serverTimezone=UTC

# Override the local otlp-endpoint to reach the inline `jaeger` compose service.
OTEL_ENDPOINT=http://jaeger:4318/v1/traces

# Hostname for `just db-migrate`'s flyway JDBC URL.
MYSQL_HOST=mysql

# Integration tests run against the dedicated inline `mysql-test` service.
# It's a separate container from the dev `mysql`, mirroring the host's
# docker-compose.yml / docker-compose.test.yml split. Migrations are applied
# automatically on first start via mounted initdb files, so no in-agent
# flyway run is needed.
TEST_DB_HOST=mysql-test
TEST_DB_PORT=3306
TEST_DB_USER=root
TEST_DB_PASSWORD=localPassword

# Marker for just recipes that need to know they're running inside the
# devcontainer (e.g. `test-it` skips the host-side docker dance).
DEVCONTAINER=1
